<Application x:Class="VocabHelper.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:VocabHelper.WPF"
             xmlns:vm="clr-namespace:VocabHelper.WPF.Business.ViewModels;assembly=VocabHelper.WPF.Business"
             xmlns:v="clr-namespace:VocabHelper.WPF.Views"
             Startup="Application_Startup"
             Exit="Application_Exit"
             >
    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:CandidateToCardMappingViewModel}">
            <v:CandidateToCardMappingView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoadTextViewModel}">
            <v:LoadRawTextView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MessageBoxViewModel}">
            <v:MessageBoxView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoadEBookViewModel}">
            <v:LoadEBookView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EBookViewModel}">
            <v:EBookView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <v:MainView />
        </DataTemplate>
    </Application.Resources>
</Application>
