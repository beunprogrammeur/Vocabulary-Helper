<UserControl x:Class="VocabHelper.WPF.Views.CandidateToCardMappingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VocabHelper.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCardTypesCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="33*" />
            <ColumnDefinition Width="33*" />
            <ColumnDefinition Width="33*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="24" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
            <RowDefinition Height="160" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Label Grid.Row="0" VerticalContentAlignment="Top">Anki card type:</Label>
        <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding CardTypes}" SelectedValue="{Binding SelectedCardType, UpdateSourceTrigger=PropertyChanged}"/>
        <Label Grid.Row="1" VerticalContentAlignment="Top">Target deck:</Label>
        <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding Decks}" SelectedValue="{Binding SelectedDeck, UpdateSourceTrigger=PropertyChanged}"/>

        <GroupBox Grid.Column="0" Grid.Row="2" Grid.RowSpan="2" Header="Anki fields">
            <ListBox ItemsSource="{Binding AnkiFields}" SelectedValue="{Binding SelectedAnkiField,UpdateSourceTrigger=PropertyChanged}"/>
        </GroupBox>
        <GroupBox Grid.Column="1" Grid.Row="2" Grid.RowSpan="2" Header="Candidate fields">
            <ListBox ItemsSource="{Binding CandidateFields}" SelectedValue="{Binding SelectedCandidateField,UpdateSourceTrigger=PropertyChanged}"/>
        </GroupBox>
        <GroupBox Grid.Column="2" Grid.Row="2" Header="Mapping">
            <ListBox ItemsSource="{Binding Mappings}" SelectedValue="{Binding SelectedMapping}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding CandidateField}" />
                            <Run Text=" -> " />
                            <Run Text="{Binding CardField}" />
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
        <GroupBox Grid.Column="2" Grid.Row="3" Header="Tags">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ListBox Grid.Row="0" Grid.ColumnSpan="999" ItemsSource="{Binding Tags}" SelectedValue="{Binding SelectedTag}"></ListBox>
                <TextBox Grid.Row="1" Grid.ColumnSpan="999" Text="{Binding TagCandidate, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="2" Grid.Column="0" Command="{Binding AddTagCommand}">Add</Button>
                <Button Grid.Row="2" Grid.Column="1" Command="{Binding RemoveTagCommand}">Remove</Button>
            </Grid>
        </GroupBox>
        <Button Grid.ColumnSpan="2" Grid.Row="4" Command="{Binding MapCommand}">^--- Map ---^</Button>
        <Button Grid.Column="2" Grid.Row="4" Command="{Binding UnMapCommand}">Unmap</Button>
        <Button Grid.ColumnSpan="999" Grid.Row="5" Command="{Binding AcceptMappingCommand}">Accept</Button>
    </Grid>
</UserControl>
