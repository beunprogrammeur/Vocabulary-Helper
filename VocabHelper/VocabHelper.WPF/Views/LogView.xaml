<UserControl x:Class="VocabHelper.WPF.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VocabHelper.WPF.Views"
             xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
             xmlns:behaviours="clr-namespace:VocabHelper.WPF.Behaviours"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <avalonEdit:TextEditor Grid.Row="1" Grid.ColumnSpan="999" FontFamily="Consolas" IsReadOnly="True" ShowLineNumbers="True" WordWrap="True" behaviours:AvalonEditLogBehaviour.LogItemsSource="{Binding LogEntries}"  />
</UserControl>
