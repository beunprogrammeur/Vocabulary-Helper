<Window x:Class="VocabHelper.WPF.Windows.DragAndDropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VocabHelper.WPF.Windows"
        mc:Ignorable="d"
        Title="DragAndDropWindow" Height="450" Width="450"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Border AllowDrop="True"
        Background="#22FFFFFF"
        Padding="40"
        CornerRadius="8">
        <TextBlock Text="Drop EPUB file here" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>

</Window>
